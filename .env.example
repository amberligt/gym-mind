# Frontend (Vite) – used in browser
VITE_SUPABASE_URL=https://YOUR-PROJECT-ID.supabase.co
VITE_SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY
VITE_SENTRY_DSN=YOUR_SENTRY_DSN_OR_LEAVE_EMPTY

# API server (Vercel / local) – used by api/claude-workout only; never expose in frontend
# If you deploy to Vercel: set these in Project Settings → Environment Variables
CLAUDE_API_KEY=your_anthropic_api_key
SUPABASE_URL=https://YOUR-PROJECT-ID.supabase.co
SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY
